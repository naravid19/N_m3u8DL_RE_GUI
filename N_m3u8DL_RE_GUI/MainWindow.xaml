<Window x:Class="N_m3u8DL_RE_GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:N_m3u8DL_RE_GUI"
        xmlns:props="clr-namespace:N_m3u8DL_RE_GUI.Properties"
        mc:Ignorable="d"
        Title="N_m3u8DL-RE GUI v2.1.0" 
        Height="850" Width="650"
        MinHeight="750" MinWidth="580"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Closing="Window_Closing" 
        Loaded="Window_Loaded"
        Background="#FF1E1E1E"
        DataContext="{Binding Source={StaticResource Locator}, Path=MainViewModel}">
    
    <Window.Resources>
        <!-- Style for Labels -->
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFE0E0E0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Width" Value="75"/>
        </Style>
        
        <!-- Style for TextBoxes -->
        <Style x:Key="TextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#FF2D2D30"/>
            <Setter Property="Foreground" Value="#FFF1F1F1"/>
            <Setter Property="BorderBrush" Value="#FF3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5,3"/>
            <Setter Property="CaretBrush" Value="#FFF1F1F1"/>
            <Setter Property="SelectionBrush" Value="#FF007ACC"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#FF007ACC"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#FF007ACC"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Style for Checkboxes -->
        <Style x:Key="CheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FFE0E0E0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,3"/>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Foreground" Value="#FF2ECC71"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Style for Buttons -->
        <Style x:Key="ButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FF0E639C"/>
            <Setter Property="Foreground" Value="#FFFFFFFF"/>
            <Setter Property="BorderBrush" Value="#FF1177BB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF1177BB"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#FF094771"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Style for Secondary Buttons -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FFE0E0E0"/>
            <Setter Property="BorderBrush" Value="#FF3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF3F3F46"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Style for GroupBox -->
        <Style x:Key="GroupBoxStyle" TargetType="GroupBox">
            <Setter Property="Foreground" Value="#FF007ACC"/>
            <Setter Property="BorderBrush" Value="#FF3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="Padding" Value="5"/>
        </Style>
        
        <!-- Style for ComboBox -->
        <Style x:Key="ComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#FF1E1E1E"/>
            <Setter Property="Background" Value="#FFFFFFFF"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#FF007ACC"/>
                    <Setter Property="Foreground" Value="#FFFFFFFF"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FFDCEBFA"/>
                    <Setter Property="Foreground" Value="#FF1E1E1E"/>
                </Trigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsSelected" Value="True"/>
                        <Condition Property="IsHighlighted" Value="True"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="#FF007ACC"/>
                    <Setter Property="Foreground" Value="#FFFFFFFF"/>
                </MultiTrigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#FF7A7A7A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#FFFFFFFF"/>
            <Setter Property="Foreground" Value="#FF1E1E1E"/>
            <Setter Property="BorderBrush" Value="#FF3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5,3"/>
            <Setter Property="MinHeight" Value="24"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource ComboBoxItemStyle}"/>
            <Style.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#FFFFFFFF"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#FFFFFFFF"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#FF1E1E1E"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#FF007ACC"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFFFFFFF"/>
            </Style.Resources>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#FF007ACC"/>
                </Trigger>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="#FF007ACC"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Style for Expander (collapsible sections) -->
        <Style x:Key="ExpanderStyle" TargetType="Expander">
            <Setter Property="Foreground" Value="#FF007ACC"/>
            <Setter Property="Background" Value="#FF1E1E1E"/>
            <Setter Property="BorderBrush" Value="#FF3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,3"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>
    
    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#FF1E1E1E">
        <StackPanel Margin="12">
            
            <!-- ================== HEADER ================== -->
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="N_m3u8DL-RE GUI" FontSize="18" FontWeight="SemiBold" Foreground="#FF007ACC"/>
                <CheckBox Grid.Column="1" x:Name="CheckBox_TopMost" Style="{StaticResource CheckBoxStyle}"
                          Content="Always on Top" ToolTip="Keep window on top"
                          Checked="SetTopMost" Unchecked="SetTopMost"/>
            </Grid>
            
            <!-- ================== BASIC SETTINGS ================== -->
            <GroupBox Header="Basic Settings" Style="{StaticResource GroupBoxStyle}">
                <StackPanel>
                    <!-- Executable Path -->
                    <Grid Margin="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="75"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Executable" Style="{StaticResource LabelStyle}"/>
                        <TextBox Grid.Column="1" x:Name="TextBox_EXE" Text="N_m3u8DL-RE.exe" 
                                 Style="{StaticResource TextBoxStyle}" TextChanged="TextChanged"
                                 ToolTip="Path to N_m3u8DL-RE executable">
                            <TextBox.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Cut" Command="Cut"/>
                                    <MenuItem Header="Copy" Command="Copy"/>
                                    <MenuItem Header="Paste" Command="Paste"/>
                                    <Separator/>
                                    <MenuItem Header="Get Downloader" Click="Menu_GetDownloader"/>
                                </ContextMenu>
                            </TextBox.ContextMenu>
                        </TextBox>
                    </Grid>
                    
                    <!-- Working Directory -->
                    <Grid Margin="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="75"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Save Dir" Style="{StaticResource LabelStyle}"/>
                        <TextBox Grid.Column="1" x:Name="TextBox_WorkDir" Style="{StaticResource TextBoxStyle}" 
                                 TextChanged="TextChanged" ToolTip="Output directory for downloads"/>
                        <Button Grid.Column="2" Content="Browse" Style="{StaticResource SecondaryButtonStyle}"
                                Click="Button_SelectDir_Click" Margin="5,0,0,0"/>
                    </Grid>

                    <!-- Temp Directory -->
                    <Grid Margin="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="75"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Tmp Dir" Style="{StaticResource LabelStyle}"/>
                        <TextBox Grid.Column="1" x:Name="TextBox_TmpDir" Style="{StaticResource TextBoxStyle}"
                                 TextChanged="TextChanged"
                                 ToolTip="Temporary directory for segment files"/>
                    </Grid>
                    
                    <!-- M3U8 URL -->
                    <Grid Margin="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="75"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Input URL" Style="{StaticResource LabelStyle}"/>
                        <TextBox Grid.Column="1" x:Name="TextBox_URL" Style="{StaticResource TextBoxStyle}" 
                                 TextChanged="TextChanged" AllowDrop="True"
                                 PreviewKeyDown="TextBox_URL_PreviewKeyDown"
                                 MouseDoubleClick="TextBox_URL_MouseDoubleClick"
                                 PreviewDragOver="TextBox_URL_PreviewDragOver"
                                 PreviewDrop="TextBox_URL_PreviewDrop"
                                 PreviewDragEnter="TextBox_URL_PreviewDragEnter"
                                 ToolTip="M3U8/MPD/ISM URL or local file path. Double-click to paste from clipboard"/>
                    </Grid>
                    
                    <!-- Save Name -->
                    <Grid Margin="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="75"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Save Name" Style="{StaticResource LabelStyle}"/>
                        <TextBox Grid.Column="1" x:Name="TextBox_Title" Style="{StaticResource TextBoxStyle}" 
                                 TextChanged="TextChanged"
                                 PreviewKeyDown="TextBox_Title_PreviewKeyDown"
                                 MouseDoubleClick="TextBox_Title_MouseDoubleClick"
                                 ToolTip="Output filename. Double-click to auto-detect from URL"/>
                    </Grid>
                </StackPanel>
            </GroupBox>
            
            <!-- ================== NETWORK SETTINGS ================== -->
            <Expander Header="Network Settings" Style="{StaticResource ExpanderStyle}" IsExpanded="False">
                <StackPanel>
                    <!-- Headers -->
                    <Grid Margin="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="75"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Headers" Style="{StaticResource LabelStyle}"/>
                        <TextBox Grid.Column="1" x:Name="TextBox_Headers" Style="{StaticResource TextBoxStyle}" 
                                 TextChanged="TextChanged"
                                 ToolTip="HTTP headers separated by | (e.g., Cookie:xxx|User-Agent:yyy)"/>
                    </Grid>
                    
                    <!-- Base URL -->
                    <Grid Margin="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="75"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Base URL" Style="{StaticResource LabelStyle}"/>
                        <TextBox Grid.Column="1" x:Name="TextBox_Baseurl" Style="{StaticResource TextBoxStyle}" 
                                 TextChanged="TextChanged"
                                 ToolTip="Override base URL for relative paths"/>
                    </Grid>
                    
                    <!-- Proxy -->
                    <Grid Margin="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="75"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Proxy" Style="{StaticResource LabelStyle}"/>
                        <TextBox Grid.Column="1" x:Name="TextBox_Proxy" Style="{StaticResource TextBoxStyle}" 
                                 TextChanged="TextChanged"
                                 ToolTip="HTTP/SOCKS5 proxy (e.g., http://127.0.0.1:8080)"/>
                    </Grid>
                </StackPanel>
            </Expander>
            
            <!-- ================== ENCRYPTION SETTINGS ================== -->
            <Expander Header="Encryption" Style="{StaticResource ExpanderStyle}" IsExpanded="False">
                <StackPanel>
                    <!-- Decryption Key -->
                    <Grid Margin="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="75"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Key" Style="{StaticResource LabelStyle}"/>
                        <TextBox Grid.Column="1" x:Name="TextBox_Key" Style="{StaticResource TextBoxStyle}" 
                                 TextChanged="TextChanged" AllowDrop="True"
                                 PreviewDragEnter="TextBox_Key_PreviewDragEnter"
                                 PreviewDragOver="TextBox_Key_PreviewDragOver"
                                 PreviewDrop="TextBox_Key_PreviewDrop"
                                 ToolTip="Decryption key (HEX/Base64) or path to key file. Supports KID:KEY format"/>
                    </Grid>

                    <!-- Custom HLS Key -->
                    <Grid Margin="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="75"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="HLS Key" Style="{StaticResource LabelStyle}"/>
                        <TextBox Grid.Column="1" x:Name="TextBox_CustomHLSKey" Style="{StaticResource TextBoxStyle}"
                                 TextChanged="TextChanged"
                                 ToolTip="Custom HLS key (HEX/Base64) for --custom-hls-key"/>
                    </Grid>
                    
                    <!-- Custom HLS IV -->
                    <Grid Margin="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="75"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="IV" Style="{StaticResource LabelStyle}"/>
                        <TextBox Grid.Column="1" x:Name="TextBox_IV" Style="{StaticResource TextBoxStyle}" 
                                 TextChanged="TextChanged"
                                 ToolTip="Custom HLS initialization vector (HEX/Base64)"/>
                    </Grid>
                </StackPanel>
            </Expander>
            
            <!-- ================== TIME RANGE ================== -->
            <Expander Header="Time Range" Style="{StaticResource ExpanderStyle}" IsExpanded="False">
                <Grid Margin="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="75"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Range" Style="{StaticResource LabelStyle}"/>
                    <TextBox Grid.Column="1" x:Name="TextBox_RangeStart" Text="00:00:00" 
                             Style="{StaticResource TextBoxStyle}" TextChanged="TextChanged"
                             ToolTip="Start time (HH:mm:ss) or segment index"/>
                    <TextBlock Grid.Column="2" Text="—" HorizontalAlignment="Center" VerticalAlignment="Center" 
                               Foreground="#FFE0E0E0"/>
                    <TextBox Grid.Column="3" x:Name="TextBox_RangeEnd" Text="00:00:00" 
                             Style="{StaticResource TextBoxStyle}" TextChanged="TextChanged"
                             ToolTip="End time (HH:mm:ss) or segment index"/>
                </Grid>
            </Expander>
            
            <!-- ================== DOWNLOAD OPTIONS ================== -->
            <Expander Header="Download Options" Style="{StaticResource ExpanderStyle}" IsExpanded="True">
              <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Row 0 -->
                    <CheckBox Grid.Row="0" Grid.Column="0" x:Name="CheckBox_Del" Style="{StaticResource CheckBoxStyle}"
                              Content="Delete After Done" ToolTip="Delete temporary files after merge"
                              Checked="CheckBoxChanged" Unchecked="CheckBoxChanged"/>
                    <CheckBox Grid.Row="0" Grid.Column="1" x:Name="CheckBox_DisableDate" Style="{StaticResource CheckBoxStyle}"
                              Content="No Date Info" ToolTip="Don't write date info during muxing"
                              Checked="CheckBoxChanged" Unchecked="CheckBoxChanged"/>
                    <CheckBox Grid.Row="0" Grid.Column="2" x:Name="CheckBox_DisableProxy" Style="{StaticResource CheckBoxStyle}"
                              Content="No System Proxy" ToolTip="Disable system proxy"
                              Checked="CheckBoxChanged" Unchecked="CheckBoxChanged"/>
                    
                    <!-- Row 1 -->
                    <CheckBox Grid.Row="1" Grid.Column="0" x:Name="CheckBox_ParserOnly" Style="{StaticResource CheckBoxStyle}"
                              Content="Skip Download" ToolTip="Parse only, don't download"
                              Checked="CheckBoxChanged" Unchecked="CheckBoxChanged"/>
                    <CheckBox Grid.Row="1" Grid.Column="1" x:Name="CheckBox_Concurrent" Style="{StaticResource CheckBoxStyle}"
                              Content="Concurrent DL" ToolTip="Download audio/video/subtitle concurrently"
                              Checked="CheckBoxChanged" Unchecked="CheckBoxChanged"/>
                    <CheckBox Grid.Row="1" Grid.Column="2" x:Name="CheckBox_DisableMerge" Style="{StaticResource CheckBoxStyle}"
                              Content="Skip Merge" ToolTip="Don't merge segments after download"
                              Checked="CheckBoxChanged" Unchecked="CheckBoxChanged"/>
                    
                    <!-- Row 2 -->
                    <CheckBox Grid.Row="2" Grid.Column="0" x:Name="CheckBox_BinaryMerge" Style="{StaticResource CheckBoxStyle}"
                              Content="Binary Merge" ToolTip="Use binary concatenation instead of ffmpeg"
                              Checked="CheckBoxChanged" Unchecked="CheckBoxChanged"/>
                    <CheckBox Grid.Row="2" Grid.Column="1" x:Name="CheckBox_AudioOnly" Style="{StaticResource CheckBoxStyle}"
                              Content="Audio Only" ToolTip="Download only audio tracks"
                              Checked="CheckBoxChanged" Unchecked="CheckBoxChanged"/>
                    <CheckBox Grid.Row="2" Grid.Column="2" x:Name="CheckBox_DisableCheck" Style="{StaticResource CheckBoxStyle}"
                              Content="Skip Check" ToolTip="Don't verify segment count"
                              Checked="CheckBoxChanged" Unchecked="CheckBoxChanged"/>
                    
                    <!-- Row 3 -->
                    <CheckBox Grid.Row="3" Grid.Column="0" x:Name="CheckBox_SubOnly" Style="{StaticResource CheckBoxStyle}"
                              Content="Subtitle Only" ToolTip="Download only subtitles"
                              Checked="CheckBoxChanged" Unchecked="CheckBoxChanged"/>
                    <CheckBox Grid.Row="3" Grid.Column="1" x:Name="CheckBox_AutoSubFix" Style="{StaticResource CheckBoxStyle}"
                              Content="Auto Sub Fix" ToolTip="Automatically fix subtitle timing"
                              Checked="CheckBoxChanged" Unchecked="CheckBoxChanged"/>
                    <CheckBox Grid.Row="3" Grid.Column="2" x:Name="CheckBox_AutoSelect" Style="{StaticResource CheckBoxStyle}"
                              Content="Auto Select" ToolTip="Automatically select best quality"
                              Checked="CheckBoxChanged" Unchecked="CheckBoxChanged"/>
                </Grid>
                
                <!-- Sub Format -->
                <Grid Margin="5,5,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Sub Format:" Foreground="#FFE0E0E0" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Normal"/>
                    <ComboBox Grid.Column="1" x:Name="Combo_SubFormat" SelectedIndex="0"
                              SelectionChanged="Combo_SubFormat_SelectionChanged">
                        <ComboBoxItem Content="SRT"/>
                        <ComboBoxItem Content="VTT"/>
                    </ComboBox>
                </Grid>
              </StackPanel>
            </Expander>
            
            <!-- ================== PERFORMANCE SETTINGS ================== -->
            <Expander Header="Performance" Style="{StaticResource ExpanderStyle}" IsExpanded="False">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Threads -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="3">
                        <TextBlock Text="Threads" Foreground="#FFE0E0E0" Width="55" VerticalAlignment="Center"/>
                        <TextBox x:Name="TextBox_Max" Text="12" Width="50" Style="{StaticResource TextBoxStyle}"
                                 TextChanged="TextChanged" HorizontalContentAlignment="Center"
                                 ToolTip="Maximum download threads"/>
                    </StackPanel>
                    
                    <!-- Retry -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="3">
                        <TextBlock Text="Retry" Foreground="#FFE0E0E0" Width="40" VerticalAlignment="Center"/>
                        <TextBox x:Name="TextBox_Retry" Text="3" Width="40" Style="{StaticResource TextBoxStyle}"
                                 TextChanged="TextChanged" HorizontalContentAlignment="Center"
                                 ToolTip="Retry count on failure"/>
                    </StackPanel>
                    
                    <!-- Timeout -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="3">
                        <TextBlock Text="Timeout" Foreground="#FFE0E0E0" Width="55" VerticalAlignment="Center"/>
                        <TextBox x:Name="TextBox_Timeout" Text="100" Width="50" Style="{StaticResource TextBoxStyle}"
                                 TextChanged="TextChanged" HorizontalContentAlignment="Center"
                                 ToolTip="HTTP timeout in seconds"/>
                    </StackPanel>
                    
                    <!-- Max Speed -->
                    <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="3">
                        <TextBlock Text="Limit" Foreground="#FFE0E0E0" Width="35" VerticalAlignment="Center"/>
                        <TextBox x:Name="TextBox_MaxSpeed" Text="" Width="50" Style="{StaticResource TextBoxStyle}"
                                 TextChanged="TextChanged" HorizontalContentAlignment="Center"
                                 ToolTip="Speed limit (e.g., 15M or 500K)"/>
                    </StackPanel>
                </Grid>
            </Expander>
            
            <!-- ================== MUX IMPORT ================== -->
            <Expander Header="Mux Import" Style="{StaticResource ExpanderStyle}" IsExpanded="False">
                <Grid Margin="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="75"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Import" Style="{StaticResource LabelStyle}"/>
                    <TextBox Grid.Column="1" x:Name="TextBox_MuxJson" Style="{StaticResource TextBoxStyle}" 
                             TextChanged="TextChanged" AllowDrop="True"
                             PreviewDragEnter="TextBox_MuxJson_PreviewDragEnter"
                             PreviewDragOver="TextBox_MuxJson_PreviewDragOver"
                             PreviewDrop="TextBox_MuxJson_PreviewDrop"
                             ToolTip="Enter mux import value or drag a file path"/>
                </Grid>
            </Expander>
            
            <!-- ================== MUX AFTER DONE ================== -->
            <Expander Header="Mux After Done" Style="{StaticResource ExpanderStyle}" IsExpanded="False">
                <StackPanel>
                    <Grid Margin="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" x:Name="CheckBox_MuxAfterDone" Style="{StaticResource CheckBoxStyle}"
                                  Content="Enable Mux" ToolTip="Mux audio/video after download completes"
                                  Checked="CheckBoxChanged" Unchecked="CheckBoxChanged"/>
                        <CheckBox Grid.Column="1" x:Name="CheckBox_MuxKeepFiles" Style="{StaticResource CheckBoxStyle}"
                                  Content="Keep Files" ToolTip="Keep original files after muxing"
                                  Checked="CheckBoxChanged" Unchecked="CheckBoxChanged"/>
                        <CheckBox Grid.Column="2" x:Name="CheckBox_MuxSkipSub" Style="{StaticResource CheckBoxStyle}"
                                  Content="Skip Subtitles" ToolTip="Skip subtitle files during mux"
                                  Checked="CheckBoxChanged" Unchecked="CheckBoxChanged"/>
                    </Grid>
                    <Grid Margin="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="75"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="75"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="75"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Format" Foreground="#FFE0E0E0" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1" x:Name="Combo_MuxFormat" SelectedIndex="0"
                                  SelectionChanged="Combo_MuxFormat_SelectionChanged">
                            <ComboBoxItem Content="mp4"/>
                            <ComboBoxItem Content="mkv"/>
                        </ComboBox>
                        <TextBlock Grid.Column="3" Text="Muxer" Foreground="#FFE0E0E0" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="4" x:Name="Combo_Muxer" SelectedIndex="0"
                                  SelectionChanged="Combo_Muxer_SelectionChanged">
                            <ComboBoxItem Content="ffmpeg"/>
                            <ComboBoxItem Content="mkvmerge"/>
                        </ComboBox>
                        <TextBlock Grid.Column="6" Text="Bin Path" Foreground="#FFE0E0E0" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="7" x:Name="TextBox_MuxBinPath" Style="{StaticResource TextBoxStyle}" 
                                 TextChanged="TextChanged"
                                 ToolTip="Path to muxer binary (auto-detected if empty)"/>
                    </Grid>
                </StackPanel>
            </Expander>
            
            <!-- ================== LIVE RECORDING ================== -->
            <Expander Header="Live Recording" Style="{StaticResource ExpanderStyle}" IsExpanded="False">
                <StackPanel>
                    <Grid Margin="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <CheckBox Grid.Row="0" Grid.Column="0" x:Name="CheckBox_LivePerformAsVod" Style="{StaticResource CheckBoxStyle}"
                                  Content="Perform as VOD" ToolTip="Download live stream as VOD"
                                  Checked="CheckBoxChanged" Unchecked="CheckBoxChanged"/>
                        <CheckBox Grid.Row="0" Grid.Column="1" x:Name="CheckBox_LiveRealTimeMerge" Style="{StaticResource CheckBoxStyle}"
                                  Content="Realtime Merge" ToolTip="Merge segments in real-time during live recording"
                                  Checked="CheckBoxChanged" Unchecked="CheckBoxChanged"/>
                        <CheckBox Grid.Row="0" Grid.Column="2" x:Name="CheckBox_LiveKeepSegments" Style="{StaticResource CheckBoxStyle}"
                                  Content="Keep Segments" ToolTip="Keep segment files during real-time merge" IsChecked="True"
                                  Checked="CheckBoxChanged" Unchecked="CheckBoxChanged"/>
                        <CheckBox Grid.Row="1" Grid.Column="0" x:Name="CheckBox_LivePipeMux" Style="{StaticResource CheckBoxStyle}"
                                  Content="Pipe Mux" ToolTip="Pipe live segments to ffmpeg for real-time TS muxing"
                                  Checked="CheckBoxChanged" Unchecked="CheckBoxChanged"/>
                        <CheckBox Grid.Row="1" Grid.Column="1" x:Name="CheckBox_LiveFixVttByAudio" Style="{StaticResource CheckBoxStyle}"
                                  Content="Fix VTT by Audio" ToolTip="Fix VTT subtitle timing using audio start time"
                                  Checked="CheckBoxChanged" Unchecked="CheckBoxChanged"/>
                    </Grid>
                    <Grid Margin="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="3">
                            <TextBlock Text="Rec Limit" Foreground="#FFE0E0E0" Width="60" VerticalAlignment="Center"/>
                            <TextBox x:Name="TextBox_LiveRecordLimit" Width="70" Style="{StaticResource TextBoxStyle}"
                                     TextChanged="TextChanged" HorizontalContentAlignment="Center"
                                     ToolTip="Recording time limit (HH:mm:ss)"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="3">
                            <TextBlock Text="Wait (s)" Foreground="#FFE0E0E0" Width="55" VerticalAlignment="Center"/>
                            <TextBox x:Name="TextBox_LiveWaitTime" Width="50" Style="{StaticResource TextBoxStyle}"
                                     TextChanged="TextChanged" HorizontalContentAlignment="Center"
                                     ToolTip="Playlist refresh interval in seconds"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="3">
                            <TextBlock Text="Take" Foreground="#FFE0E0E0" Width="40" VerticalAlignment="Center"/>
                            <TextBox x:Name="TextBox_LiveTakeCount" Text="16" Width="50" Style="{StaticResource TextBoxStyle}"
                                     TextChanged="TextChanged" HorizontalContentAlignment="Center"
                                     ToolTip="Initial segment count for live recording (default: 16)"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Expander>
            
            <!-- ================== STREAM SELECTION ================== -->
            <Expander Header="Stream Selection (Regex)" Style="{StaticResource ExpanderStyle}" IsExpanded="False">
                <StackPanel>
                    <!-- Select Streams -->
                    <Grid Margin="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="75"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Select Video" Style="{StaticResource LabelStyle}"/>
                        <TextBox Grid.Column="1" x:Name="TextBox_SelectVideo" Style="{StaticResource TextBoxStyle}" 
                                 TextChanged="TextChanged"
                                 ToolTip="Regex to select video streams (e.g., res=&quot;3840*&quot;:codecs=hvc1:for=best)"/>
                    </Grid>
                    <Grid Margin="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="75"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Select Audio" Style="{StaticResource LabelStyle}"/>
                        <TextBox Grid.Column="1" x:Name="TextBox_SelectAudio" Style="{StaticResource TextBoxStyle}" 
                                 TextChanged="TextChanged"
                                 ToolTip="Regex to select audio streams (e.g., lang=en:for=best)"/>
                    </Grid>
                    <Grid Margin="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="75"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Select Sub" Style="{StaticResource LabelStyle}"/>
                        <TextBox Grid.Column="1" x:Name="TextBox_SelectSubtitle" Style="{StaticResource TextBoxStyle}" 
                                 TextChanged="TextChanged"
                                 ToolTip="Regex to select subtitle streams (e.g., name=&quot;中文&quot;:for=all)"/>
                    </Grid>
                    <!-- Drop Streams -->
                    <Grid Margin="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="75"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Drop Video" Style="{StaticResource LabelStyle}" Foreground="#FFE74C3C"/>
                        <TextBox Grid.Column="1" x:Name="TextBox_DropVideo" Style="{StaticResource TextBoxStyle}" 
                                 TextChanged="TextChanged"
                                 ToolTip="Regex to drop/exclude video streams"/>
                    </Grid>
                    <Grid Margin="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="75"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Drop Audio" Style="{StaticResource LabelStyle}" Foreground="#FFE74C3C"/>
                        <TextBox Grid.Column="1" x:Name="TextBox_DropAudio" Style="{StaticResource TextBoxStyle}" 
                                 TextChanged="TextChanged"
                                 ToolTip="Regex to drop/exclude audio streams"/>
                    </Grid>
                    <Grid Margin="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="75"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Drop Sub" Style="{StaticResource LabelStyle}" Foreground="#FFE74C3C"/>
                        <TextBox Grid.Column="1" x:Name="TextBox_DropSubtitle" Style="{StaticResource TextBoxStyle}" 
                                 TextChanged="TextChanged"
                                 ToolTip="Regex to drop/exclude subtitle streams"/>
                    </Grid>
                </StackPanel>
            </Expander>
            
            <!-- ================== DECRYPTION ENGINE ================== -->
            <Expander Header="Decryption" Style="{StaticResource ExpanderStyle}" IsExpanded="False">
                <StackPanel>
                    <Grid Margin="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="75"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="75"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Engine" Style="{StaticResource LabelStyle}"/>
                        <ComboBox Grid.Column="1" x:Name="Combo_DecryptionEngine" SelectedIndex="0"
                                  SelectionChanged="Combo_DecryptionEngine_SelectionChanged">
                            <ComboBoxItem Content="MP4DECRYPT"/>
                            <ComboBoxItem Content="SHAKA_PACKAGER"/>
                            <ComboBoxItem Content="FFMPEG"/>
                        </ComboBox>
                        <TextBlock Grid.Column="3" Text="HLS Method" Style="{StaticResource LabelStyle}"/>
                        <ComboBox Grid.Column="4" x:Name="Combo_CustomHLSMethod" SelectedIndex="0"
                                  SelectionChanged="Combo_HLSMethod_SelectionChanged">
                            <ComboBoxItem Content="(Default)"/>
                            <ComboBoxItem Content="AES_128"/>
                            <ComboBoxItem Content="AES_128_ECB"/>
                            <ComboBoxItem Content="CENC"/>
                            <ComboBoxItem Content="CHACHA20"/>
                            <ComboBoxItem Content="NONE"/>
                            <ComboBoxItem Content="SAMPLE_AES"/>
                            <ComboBoxItem Content="SAMPLE_AES_CTR"/>
                        </ComboBox>
                    </Grid>
                    <Grid Margin="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="75"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Bin Path" Style="{StaticResource LabelStyle}"/>
                        <TextBox Grid.Column="1" x:Name="TextBox_DecryptionBinPath" Style="{StaticResource TextBoxStyle}" 
                                 TextChanged="TextChanged"
                                 ToolTip="Path to decryption binary (mp4decrypt/shaka-packager)"/>
                    </Grid>
                    <Grid Margin="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="75"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Key File" Style="{StaticResource LabelStyle}"/>
                        <TextBox Grid.Column="1" x:Name="TextBox_KeyTextFile" Style="{StaticResource TextBoxStyle}" 
                                 TextChanged="TextChanged" AllowDrop="True"
                                 ToolTip="Path to key text file for decryption (searches KID:KEY pairs)"/>
                    </Grid>
                    <CheckBox x:Name="CheckBox_MP4RealTimeDecryption" Style="{StaticResource CheckBoxStyle}"
                              Content="MP4 Real-Time Decryption" ToolTip="Decrypt MP4 segments in real-time"
                              Checked="CheckBoxChanged" Unchecked="CheckBoxChanged" Margin="3"/>
                </StackPanel>
            </Expander>
            
            <!-- ================== ADVANCED SETTINGS ================== -->
            <Expander Header="Advanced" Style="{StaticResource ExpanderStyle}" IsExpanded="False">
                <StackPanel>
                    <Grid Margin="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="75"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Save Pattern" Style="{StaticResource LabelStyle}"/>
                        <TextBox Grid.Column="1" x:Name="TextBox_SavePattern" Style="{StaticResource TextBoxStyle}" 
                                 TextChanged="TextChanged"
                                 ToolTip="Save filename pattern using variables: &lt;SaveName&gt;, &lt;Resolution&gt;, &lt;Bandwidth&gt;, &lt;Language&gt;, etc."/>
                    </Grid>
                    <Grid Margin="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="75"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="FFmpeg Path" Style="{StaticResource LabelStyle}"/>
                        <TextBox Grid.Column="1" x:Name="TextBox_FFmpegPath" Style="{StaticResource TextBoxStyle}" 
                                 TextChanged="TextChanged"
                                 ToolTip="Full path to ffmpeg executable"/>
                    </Grid>
                    <Grid Margin="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="75"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Ad Keyword" Style="{StaticResource LabelStyle}"/>
                        <TextBox Grid.Column="1" x:Name="TextBox_AdKeyword" Style="{StaticResource TextBoxStyle}" 
                                 TextChanged="TextChanged"
                                 ToolTip="Regex to identify and remove ad segments"/>
                    </Grid>
                    <Grid Margin="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="75"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="URL Args" Style="{StaticResource LabelStyle}"/>
                        <TextBox Grid.Column="1" x:Name="TextBox_UrlProcessorArgs" Style="{StaticResource TextBoxStyle}"
                                 TextChanged="TextChanged"
                                 ToolTip="Arguments for --urlprocessor-args"/>
                    </Grid>
                    <Grid Margin="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="75"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Start At" Style="{StaticResource LabelStyle}"/>
                        <TextBox Grid.Column="1" x:Name="TextBox_TaskStartAt" Style="{StaticResource TextBoxStyle}"
                                 TextChanged="TextChanged"
                                 ToolTip="Task schedule time in yyyyMMddHHmmss format"/>
                    </Grid>
                    <Grid Margin="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="75"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="75"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Log Level" Style="{StaticResource LabelStyle}"/>
                        <ComboBox Grid.Column="1" x:Name="Combo_LogLevel" SelectedIndex="2"
                                  SelectionChanged="Combo_LogLevel_SelectionChanged">
                            <ComboBoxItem Content="DEBUG"/>
                            <ComboBoxItem Content="ERROR"/>
                            <ComboBoxItem Content="INFO"/>
                            <ComboBoxItem Content="WARN"/>
                            <ComboBoxItem Content="OFF"/>
                        </ComboBox>
                        <TextBlock Grid.Column="3" Text="UI Language" Style="{StaticResource LabelStyle}"/>
                        <ComboBox Grid.Column="4" x:Name="Combo_UILanguage" SelectedIndex="0"
                                  SelectionChanged="Combo_UILanguage_SelectionChanged">
                            <ComboBoxItem Content="(Default)"/>
                            <ComboBoxItem Content="en-US"/>
                            <ComboBoxItem Content="zh-CN"/>
                            <ComboBoxItem Content="zh-TW"/>
                        </ComboBox>
                    </Grid>
                    <Grid Margin="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <CheckBox Grid.Row="0" Grid.Column="0" x:Name="CheckBox_AppendUrlParams" Style="{StaticResource CheckBoxStyle}"
                                  Content="Append URL Params" ToolTip="Add input URL params to segment URLs"
                                  Checked="CheckBoxChanged" Unchecked="CheckBoxChanged"/>
                        <CheckBox Grid.Row="0" Grid.Column="1" x:Name="CheckBox_NoLog" Style="{StaticResource CheckBoxStyle}"
                                  Content="No Log" ToolTip="Disable log file output"
                                  Checked="CheckBoxChanged" Unchecked="CheckBoxChanged"/>
                        <CheckBox Grid.Row="0" Grid.Column="2" x:Name="CheckBox_WriteMetaJson" Style="{StaticResource CheckBoxStyle}"
                                  Content="Write Meta JSON" ToolTip="Output parsed info as JSON" IsChecked="True"
                                  Checked="CheckBoxChanged" Unchecked="CheckBoxChanged"/>
                        <CheckBox Grid.Row="1" Grid.Column="0" x:Name="CheckBox_UseFFmpegConcat" Style="{StaticResource CheckBoxStyle}"
                                  Content="FFmpeg Concat" ToolTip="Use ffmpeg concat demuxer instead of concat protocol"
                                  Checked="CheckBoxChanged" Unchecked="CheckBoxChanged"/>
                        <CheckBox Grid.Row="1" Grid.Column="1" x:Name="CheckBox_AllowHlsMultiExtMap" Style="{StaticResource CheckBoxStyle}"
                                  Content="Multi EXT-MAP" ToolTip="Allow multiple #EXT-X-MAP in HLS (experimental)"
                                  Checked="CheckBoxChanged" Unchecked="CheckBoxChanged"/>
                        <CheckBox Grid.Row="1" Grid.Column="2" x:Name="CheckBox_DisableUpdateCheck" Style="{StaticResource CheckBoxStyle}"
                                  Content="No Update Check" ToolTip="Disable version update checking"
                                  Checked="CheckBoxChanged" Unchecked="CheckBoxChanged"/>
                        <CheckBox Grid.Row="2" Grid.Column="0" x:Name="CheckBox_ForceAnsiConsole" Style="{StaticResource CheckBoxStyle}"
                                  Content="Force ANSI Console" ToolTip="Force ANSI-enabled console mode"
                                  Checked="CheckBoxChanged" Unchecked="CheckBoxChanged"/>
                        <CheckBox Grid.Row="2" Grid.Column="1" x:Name="CheckBox_NoAnsiColor" Style="{StaticResource CheckBoxStyle}"
                                  Content="No ANSI Color" ToolTip="Disable ANSI color output"
                                  Checked="CheckBoxChanged" Unchecked="CheckBoxChanged"/>
                    </Grid>
                </StackPanel>
            </Expander>
            
            <!-- ================== GENERATED PARAMETERS ================== -->
            <GroupBox Header="Generated Command" Style="{StaticResource GroupBoxStyle}">
                <Grid Margin="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TextBox_Parameter" Style="{StaticResource TextBoxStyle}" 
                             IsReadOnly="True"
                             ToolTip="Generated command-line arguments"/>
                    <Button Grid.Column="1" x:Name="Button_GO" Content="▶ GO" 
                            Style="{StaticResource ButtonStyle}"
                            Click="Button_GO_Click" Margin="10,0,0,0"
                            ToolTip="Start download (Alt+S)" FontWeight="SemiBold"/>
                </Grid>
            </GroupBox>
            
        </StackPanel>
    </ScrollViewer>
</Window>
